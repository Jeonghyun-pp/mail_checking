# Copy to .env.production on the server and fill in real values.
# This file is git-ignored once copied — never commit secrets.

# --- Postgres (runs inside the compose network) ---------------------------
POSTGRES_USER=mailchecking
POSTGRES_DB=mailchecking
# Pick a strong password:  openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME_db_password

# DATABASE_URL and REDIS_URL are assembled by docker-compose.prod.yml from the
# values above + the service hostnames — do not set them here.

# --- App ------------------------------------------------------------------
# Your Tailscale MagicDNS hostname (see DEPLOY.md). HTTPS, no port.
APP_URL=https://mailchecking.YOUR-TAILNET.ts.net

# Session-cookie signing key. MUST be changed from the default.
# Generate:  openssl rand -hex 32
AUTH_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# --- Email verification probe identity ------------------------------------
# HELO domain + MAIL FROM used when the verifier talks to remote mail servers.
# Use a domain you control for best results.
VERIFY_HELO_DOMAIN=mail-checking.local
VERIFY_MAIL_FROM=verify@mail-checking.local
